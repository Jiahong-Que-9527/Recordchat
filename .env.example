# ----- LLM -----
# provider: local | qwen | openai | claude
# 'local' needs no API key and runs fully offline (extractive answers).
LLM_PROVIDER=local
LLM_MODEL=qwen-plus
LLM_API_KEY=
LLM_BASE_URL=

# ----- Embedding -----
# provider: local | qwen | openai
# 'local' is a deterministic hashing embedding (offline, no key needed).
EMBEDDING_PROVIDER=local
EMBEDDING_MODEL=text-embedding-v4
EMBEDDING_API_KEY=
EMBEDDING_DIM=1024

# ----- Qdrant -----
# ":memory:" = embedded in-process store (offline). Use the URL for docker.
QDRANT_URL=:memory:
QDRANT_COLLECTION=recordchat_one_record

# ----- RAG -----
RAG_TOP_K=5

# ----- CORS / Frontend -----
# Local browser + local services:
#   CORS_ORIGINS=http://localhost:3000
#   NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
#
# VPS development + browser on your laptop:
#   CORS_ORIGINS=http://<your-vps-host>:3000
#   NEXT_PUBLIC_API_BASE_URL=http://<your-vps-host>:8000
#
# If NEXT_PUBLIC_API_BASE_URL is left empty, the frontend will infer
# "<current-page-host>:8000" in the browser.
CORS_ORIGINS=http://localhost:3000
NEXT_PUBLIC_API_BASE_URL=
