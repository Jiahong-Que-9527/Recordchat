# ----- LLM -----
# provider: openai | claude
LLM_PROVIDER=openai
LLM_MODEL=deepseek-v4-flash
LLM_API_KEY=
LLM_BASE_URL=

# ----- Embedding -----
# provider: openai
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=https://api.openai.com/v1
EMBEDDING_DIM=1536

# ----- Qdrant -----
# ":memory:" = embedded in-process store. Use the URL for docker.
QDRANT_URL=:memory:
QDRANT_COLLECTION=recordchat_one_record
QDRANT_UPSERT_BATCH_SIZE=128

# ----- Workflow connectors -----
RECORDFORGE_URL=
RECORDFORGE_API_KEY=

# ----- RAG -----
RAG_TOP_K=5

# ----- CORS / Frontend -----
# Local browser + local services:
#   CORS_ORIGINS=http://localhost:3000
#   NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
#   INTERNAL_API_BASE_URL=http://127.0.0.1:8000
#
# VPS development + browser on your laptop:
#   CORS_ORIGINS=http://<your-vps-host>:3000
#   NEXT_PUBLIC_API_BASE_URL=http://<your-vps-host>:8000
#   INTERNAL_API_BASE_URL=http://<your-vps-host>:8000
#
# If NEXT_PUBLIC_API_BASE_URL is left empty, the frontend will infer
# "<current-page-host>:8000" in the browser.
CORS_ORIGINS=http://localhost:3000
NEXT_PUBLIC_API_BASE_URL=
INTERNAL_API_BASE_URL=
